"events.default.estonia.body" = "The Estonian Ice Fishing Festival is one of the largest ice fishing festivals in the Baltics. It is known for its large participation and friendly atmosphere. The summer format is adapted for training areas and competitions.\n\nSchedule\nDay 1: Registration, Preparation\nDay 2: Main Round (4 hours)\nDay 3: Finals, Awards Ceremony, Festival\n\nRules\nIndividual Competition\nUp to 8 holes\nCritical Competition by Weight and Number\nMandatory Safety (Vests)\n\nRegistration\ninfo@peipsifest.ee";
"events.default.estonia.location" = "Lake Peipus, Estonia";
"events.default.estonia.title" = "Estonian Ice Fishing Festival - Peipsi Lake";
"events.default.sweden.body" = "The Swedish Ice Fishing Championship is Sweden's national ice fishing championship. During the summer, it is held as an open tournament with demonstrations of techniques, including using fish finders and fish locating.\n\nSchedule\nDay 1: Training and briefing\nDay 2: Main stage (6 hours)\nDay 3: Finals and team competition\n\nRules\nIndividual and team competition\nFish finders allowed\nCatch & Release for large fish\nFishing zone restrictions\n\nRegistration\nregistration@swedishice.se";
"events.default.sweden.location" = "Jonkoping, Sweden";
"events.default.sweden.title" = "Swedish Ice Fishing Championship";
"events.default.wifc.body" = "The World Ice Fishing Championship is one of the most famous ice fishing tournaments in the world. Its summer format is a festival-style event featuring ice fishing simulations, technique training, and competitions in specially prepared areas.\n\nSchedule\nDay 1: Registration, Draw, Briefing\nDay 2: Main Round (5 hours of fishing)\nDay 3: Final, Award Ceremony\n\nRules\nFishing with winter tackle only\nLimit: up to 5 holes\nScoring is based on the total weight of the fish\nJudges supervise each zone\n\nRegistration\ninfo@wifc-finland.org";
"events.default.wifc.location" = "Kuopio, Finland";
"events.default.wifc.title" = "World Ice Fishing Championship (WIFC) - Finland Edition";
